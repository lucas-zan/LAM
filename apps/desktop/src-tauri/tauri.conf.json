{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LocalAgentManager",
  "version": "0.1.0",
  "identifier": "dev.localagentmanager.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "LAM (LocalAgentManager)",
        "width": 1280,
        "height": 820,
        "minWidth": 1100,
        "minHeight": 700,
        "visible": false
      },
      {
        "label": "quota-popover",
        "title": "LAM Quota",
        "url": "index.html",
        "width": 328,
        "height": 520,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "backgroundColor": "#00000000",
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": true,
        "focus": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.icns",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ]
  }
}
